{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "ANcpLua framework — shared Renovate baseline (used by ANcpLua.NET.Sdk, ANcpLua.Roslyn.Utilities, ANcpLua.Analyzers, ANcpLua.Agents)",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":enableVulnerabilityAlerts"
  ],
  "timezone": "UTC",
  "dependencyDashboard": true,
  "commitMessagePrefix": "deps:",
  "labels": [
    "dependencies"
  ],
  "platformAutomerge": false,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Hygiene: digest pins + lockfile maintenance — content-locking, automerge always",
      "matchUpdateTypes": [
        "pin",
        "digest",
        "pinDigest",
        "lockFileMaintenance"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Patch bumps — automerge if CI is green (cross-ecosystem)",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "npm devDependencies — minor bumps automerge (build-time only, no runtime risk)",
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Block unstable npm versions by default — alpha/beta/rc/preview/pre/dev/canary/next/nightly",
      "matchManagers": [
        "npm"
      ],
      "allowedVersions": "!/(?:alpha|beta|rc|preview|pre|dev|canary|next|nightly)/i"
    },
    {
      "description": "Block unstable NuGet versions by default — alpha/beta/preview/pre/dev/experimental/nightly. RC is allowed; package-family exceptions below override as needed",
      "matchDatasources": [
        "nuget"
      ],
      "allowedVersions": "!/(?:alpha|beta|preview|pre|dev|experimental|nightly)/i"
    },
    {
      "description": "Known-prerelease NuGet exceptions: first-party packages plus upstreams with no stable release. Resets allowedVersions so the default-deny does not freeze legitimate prerelease pins",
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": [
        "/^ANcpLua\\./",
        "/^Qyl\\./",
        "Microsoft.OpenApi.Readers",
        "JonSkeet.RoslynAnalyzers"
      ],
      "ignoreUnstable": false,
      "respectLatest": false,
      "allowedVersions": "*"
    },
    {
      "description": "ANcpLua first-party (cross-repo) — automerge minor/patch",
      "matchPackageNames": [
        "/^ANcpLua\\./"
      ],
      "groupName": "ancplua-sdk",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Roslyn analyzers + reference assemblies",
      "matchPackageNames": [
        "/^Microsoft\\.CodeAnalysis/",
        "/^Basic\\.Reference\\.Assemblies/"
      ],
      "groupName": "roslyn",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Microsoft.Extensions / BCL / Channels / ASP.NET",
      "matchPackageNames": [
        "/^Microsoft\\.Extensions/",
        "/^Microsoft\\.Bcl/",
        "/^System\\.Threading\\.Channels/",
        "/^Microsoft\\.AspNetCore/"
      ],
      "groupName": "microsoft-extensions",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "AI client packages excluding the Microsoft Agent Framework family",
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": [
        "/^Microsoft\\.Extensions\\.AI/",
        "/^OpenAI/",
        "/^Azure\\.AI\\.OpenAI/",
        "/^Anthropic\\.SDK/",
        "/^OllamaSharp/",
        "/^Mscc\\.GenerativeAI/"
      ],
      "groupName": "ai-client-packages",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Meziantou family",
      "matchPackageNames": [
        "/^Meziantou\\./"
      ],
      "groupName": "meziantou",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Test frameworks (xUnit / NUnit / TUnit / bunit / MTP / AwesomeAssertions / Moq)",
      "matchPackageNames": [
        "/^xunit/",
        "/^NUnit/",
        "/^TUnit/",
        "/^bunit/",
        "/^Microsoft\\.Testing/",
        "/^Microsoft\\.NET\\.Test/",
        "/^AwesomeAssertions/",
        "/^Moq/",
        "/^GitHubActionsTestLogger/",
        "/^coverlet/"
      ],
      "groupName": "testing",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "OpenAPI / YAML",
      "matchPackageNames": [
        "/^Microsoft\\.OpenApi/",
        "/^YamlDotNet/"
      ],
      "groupName": "openapi",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "OpenTelemetry",
      "matchPackageNames": [
        "/^OpenTelemetry/"
      ],
      "groupName": "opentelemetry",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Major bumps require manual review by default",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "major"
      ]
    },
    {
      "description": "Microsoft Agent Framework — dynamic family rule, stable/RC versions only",
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": [
        "/^Microsoft\\.Agents\\.AI(?:\\.|$)/",
        "Aspire.Hosting.AgentFramework.DevUI"
      ],
      "groupName": "microsoft-agent-framework",
      "ignoreUnstable": false,
      "respectLatest": false,
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+(?:-[Rr][Cc]\\d+)?$/",
      "automerge": true,
      "automergeType": "pr",
      "dependencyDashboardApproval": false,
      "labels": [
        "dependencies",
        "microsoft-agent-framework"
      ],
      "prPriority": 4,
      "prBodyNotes": [
        "Dynamic Microsoft Agent Framework rule: stable and RC versions are allowed; preview/alpha/beta/dev builds are excluded without maintaining a static package matrix."
      ]
    },
    {
      "description": "MAF legacy package — migrate AzureAI naming to Foundry",
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": [
        "Microsoft.Agents.AI.AzureAI"
      ],
      "replacementName": "Microsoft.Agents.AI.Foundry",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": [
        "dependencies",
        "microsoft-agent-framework",
        "legacy",
        "migration"
      ],
      "prBodyNotes": [
        "Microsoft.Agents.AI.AzureAI is superseded by Microsoft.Agents.AI.Foundry. Renovate chooses the available replacement version dynamically. Replacement rules do not apply to custom.regex-managed Version.props entries, so Version.props migrations may require manual edits."
      ]
    },
    {
      "description": "MAF legacy package — migrate Declarative AzureAI workflows to Declarative Foundry workflows",
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": [
        "Microsoft.Agents.AI.Workflows.Declarative.AzureAI"
      ],
      "replacementName": "Microsoft.Agents.AI.Workflows.Declarative.Foundry",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": [
        "dependencies",
        "microsoft-agent-framework",
        "legacy",
        "migration"
      ],
      "prBodyNotes": [
        "Microsoft.Agents.AI.Workflows.Declarative.AzureAI is superseded by Microsoft.Agents.AI.Workflows.Declarative.Foundry. Renovate chooses the available replacement version dynamically. Replacement rules do not apply to custom.regex-managed Version.props entries, so Version.props migrations may require manual edits."
      ]
    },
    {
      "description": "MAF legacy preview package — migrate FoundryMemory to Foundry",
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": [
        "Microsoft.Agents.AI.FoundryMemory"
      ],
      "replacementName": "Microsoft.Agents.AI.Foundry",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": [
        "dependencies",
        "microsoft-agent-framework",
        "legacy",
        "preview",
        "migration"
      ],
      "prBodyNotes": [
        "Microsoft.Agents.AI.FoundryMemory is superseded by Microsoft.Agents.AI.Foundry. Renovate chooses the available replacement version dynamically. Replacement rules do not apply to custom.regex-managed Version.props entries, so Version.props migrations may require manual edits."
      ]
    }
  ]
}
